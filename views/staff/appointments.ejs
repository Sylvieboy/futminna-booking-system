<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Appointments - FUT Minna</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h6>Logged in as</h6>
            <p>👤 <%= user.full_name %></p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/staff/dashboard"><span class="icon">🏠</span> Dashboard</a></li>
            <li><a href="/staff/appointments" class="active"><span class="icon">📅</span> Appointments</a></li>
            <li><a href="/staff/bookings"><span class="icon">📋</span> My Bookings</a></li>
            <li><a href="/staff/announcements"><span class="icon">📢</span> Announcements</a></li>
            <li><a href="/logout"><span class="icon">🚪</span> Logout</a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="page-header">
            <h1>📅 Manage Appointments</h1>
            <p>Review and manage all student appointment requests</p>
        </div>

        <%- include('../partials/messages') %>

        <div class="card">
            <div class="card-header">
                <h2>📅 All Appointment Requests</h2>
            </div>
            <% if (appointments.length > 0) { %>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Purpose</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% appointments.forEach(apt => { %>
                        <tr>
                            <td><%= apt.users.full_name %></td>
                            <td><%= apt.users.email %></td>
                            <td><%= new Date(apt.appointment_date).toDateString() %></td>
                            <td><%= apt.appointment_time %></td>
                            <td><%= apt.purpose %></td>
                            <td><span class="badge badge-<%= apt.status %>"><%= apt.status %></span></td>
                            <td>
                                <% if (apt.status === 'pending') { %>
                                <a href="/staff/appointments/<%= apt.id %>/approve"
                                   class="btn btn-success btn-sm">✅ Approve</a>
                                <a href="/staff/appointments/<%= apt.id %>/reject"
                                   class="btn btn-danger btn-sm">❌ Reject</a>
                                <% } else { %>
                                <span style="color:#999; font-size:0.8rem;">Processed</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <p>No appointment requests yet.</p>
            </div>
            <% } %>
        </div>

    </main>
</div>

<footer class="footer">
    <p>© <%= new Date().getFullYear() %> Department of Information Technology, SICT, FUT Minna</p>
</footer>

</body>
</html>