<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Appointments - FUT Minna</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body> 

<%- include('../partials/navbar') %>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h6>Logged in as</h6>
            <p>👤 <%= user.full_name %></p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/admin/dashboard"><span class="icon">🏠</span> Dashboard</a></li>
            <li><a href="/admin/users"><span class="icon">👥</span> Manage Users</a></li>
            <li><a href="/admin/resources"><span class="icon">🏛️</span> Manage Resources</a></li>
            <li><a href="/admin/bookings"><span class="icon">📋</span> Manage Bookings</a></li>
            <li><a href="/admin/appointments" class="active"><span class="icon">📅</span> All Appointments</a></li>
            <li><a href="/admin/announcements"><span class="icon">📢</span> Announcements</a></li>
            <li><a href="/logout"><span class="icon">🚪</span> Logout</a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="page-header">
            <h1>📅 All Appointments</h1>
            <p>Overview of all appointment requests in the department</p>
        </div>

        <%- include('../partials/messages') %>

        <div class="card">
            <div class="card-header">
                <h2>📅 All Appointment Requests</h2>
            </div>
            <% if (appointments.length > 0) { %>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Lecturer</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Purpose</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% appointments.forEach(apt => { %>
                        <tr>
                            <td><%= apt.users ? apt.users.full_name : 'Unknown' %></td>
                            <td><%= apt.users ? apt.users.full_name : 'Unknown' %></td>
                            <td><%= new Date(apt.appointment_date).toDateString() %></td>
                            <td><%= apt.appointment_time %></td>
                            <td><%= apt.purpose %></td>
                            <td><span class="badge badge-<%= apt.status %>"><%= apt.status %></span></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <p>No appointment requests yet.</p>
            </div>
            <% } %>
        </div>

    </main>
</div>

<footer class="footer">
    <p>© <%= new Date().getFullYear() %> Department of Information Technology, SICT, FUT Minna</p>
</footer>

</body>
</html>