<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Bookings - FUT Minna</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h6>Logged in as</h6>
            <p>👤 <%= user.full_name %></p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/admin/dashboard"><span class="icon">🏠</span> Dashboard</a></li>
            <li><a href="/admin/users"><span class="icon">👥</span> Manage Users</a></li>
            <li><a href="/admin/resources"><span class="icon">🏛️</span> Manage Resources</a></li>
            <li><a href="/admin/bookings" class="active"><span class="icon">📋</span> Manage Bookings</a></li>
            <li><a href="/admin/appointments"><span class="icon">📅</span> All Appointments</a></li>
            <li><a href="/admin/announcements"><span class="icon">📢</span> Announcements</a></li>
            <li><a href="/logout"><span class="icon">🚪</span> Logout</a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="page-header">
            <h1>📋 Manage Bookings</h1>
            <p>Review and process all resource booking requests</p>
        </div>

        <%- include('../partials/messages') %>

        <div class="card">
            <div class="card-header">
                <h2>📋 All Booking Requests</h2>
            </div>
            <% if (bookings.length > 0) { %>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Resource</th>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bookings.forEach(booking => { %>
                        <tr>
                            <td><%= booking.users.full_name %></td>
                            <td><%= booking.users.email %></td>
                            <td><%= booking.resources.resource_name %></td>
                            <td><span class="badge badge-<%= booking.resources.resource_type %>">
                                <%= booking.resources.resource_type %></span></td>
                            <td><%= new Date(booking.booking_date).toDateString() %></td>
                            <td><%= booking.start_time %></td>
                            <td><%= booking.end_time %></td>
                            <td><span class="badge badge-<%= booking.status %>"><%= booking.status %></span></td>
                            <td>
                                <% if (booking.status === 'pending') { %>
                                <a href="/admin/bookings/<%= booking.id %>/approve"
                                   class="btn btn-success btn-sm">✅ Approve</a>
                                <a href="/admin/bookings/<%= booking.id %>/reject"
                                   class="btn btn-danger btn-sm">❌ Reject</a>
                                <% } else { %>
                                <span style="color:#999; font-size:0.8rem;">Processed</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <p>No booking requests yet.</p>
            </div>
            <% } %>
        </div>

    </main>
</div>

<footer class="footer">
    <p>© <%= new Date().getFullYear() %> Department of Information Technology, SICT, FUT Minna</p>
</footer>

</body>
</html>