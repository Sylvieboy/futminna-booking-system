<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Resources - FUT Minna</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h6>Logged in as</h6>
            <p>👤 <%= user.full_name %></p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/admin/dashboard"><span class="icon">🏠</span> Dashboard</a></li>
            <li><a href="/admin/users"><span class="icon">👥</span> Manage Users</a></li>
            <li><a href="/admin/resources" class="active"><span class="icon">🏛️</span> Manage Resources</a></li>
            <li><a href="/admin/bookings"><span class="icon">📋</span> Manage Bookings</a></li>
            <li><a href="/admin/appointments"><span class="icon">📅</span> All Appointments</a></li>
            <li><a href="/admin/announcements"><span class="icon">📢</span> Announcements</a></li>
            <li><a href="/logout"><span class="icon">🚪</span> Logout</a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="page-header">
            <h1>🏛️ Manage Resources</h1>
            <p>Add, update and manage departmental resources and equipment</p>
        </div>

        <%- include('../partials/messages') %>

        <!-- Add Resource Form -->
        <div class="card">
            <div class="card-header">
                <h2>➕ Add New Resource</h2>
            </div>
            <form action="/admin/resources" method="POST" style="padding: 20px;">
                <div class="form-row">
                    <div class="form-group">
                        <label>Resource Type *</label>
                        <select name="resource_type" class="form-control" required
                                id="resourceTypeSelect" onchange="handleResourceTypeChange()">
                            <option value="">-- Select type --</option>
                            <optgroup label="📍 Spaces">
                                <option value="Lecture Hall">Lecture Hall</option>
                                <option value="Computer Lab">Computer Lab</option>
                                <option value="Conference Room">Conference Room</option>
                            </optgroup>
                            <optgroup label="💻 Computer Hardware">
                                <option value="Desktop Computer">Desktop Computer</option>
                                <option value="Laptop Computer">Laptop Computer</option>
                                <option value="Monitor">Monitor</option>
                                <option value="Keyboard">Keyboard</option>
                                <option value="Mouse">Mouse</option>
                                <option value="Printer">Printer</option>
                                <option value="Scanner">Scanner</option>
                                <option value="Projector">Projector</option>
                                <option value="UPS">UPS (Uninterruptible Power Supply)</option>
                                <option value="External Hard Drive">External Hard Drive</option>
                                <option value="USB Flash Drive">USB Flash Drive</option>
                            </optgroup>
                            <optgroup label="🌐 Networking Equipment">
                                <option value="Router">Router</option>
                                <option value="Switch">Switch</option>
                                <option value="Modem">Modem</option>
                                <option value="Network Cables">Network Cables (Ethernet)</option>
                                <option value="Wireless Access Point">Wireless Access Point</option>
                                <option value="Network Interface Card">Network Interface Card (NIC)</option>
                                <option value="Patch Panel">Patch Panel</option>
                            </optgroup>
                            <optgroup label="🎵 Multimedia Equipment">
                                <option value="Speakers">Speakers</option>
                                <option value="Headphones">Headphones</option>
                                <option value="Microphone">Microphone</option>
                                <option value="Webcam">Webcam</option>
                                <option value="Digital Camera">Digital Camera</option>
                            </optgroup>
                            <optgroup label="🖥️ Classroom Teaching Equipment">
                                <option value="Smart Board">Smart Board / Interactive Whiteboard</option>
                                <option value="LCD Projector">LCD Projector</option>
                                <option value="Presentation Remote">Presentation Remote</option>
                                <option value="Document Camera">Document Camera</option>
                            </optgroup>
                            <optgroup label="📱 Mobile Devices">
                                <option value="Smartphone">Smartphone</option>
                                <option value="Tablet">Tablet</option>
                            </optgroup>
                            <optgroup label="⚡ Power and Safety Equipment">
                                <option value="Extension Cable">Extension Cable</option>
                                <option value="Surge Protector">Surge Protector</option>
                                <option value="Power Bank">Power Bank</option>
                                <option value="Voltage Stabilizer">Voltage Stabilizer</option>
                            </optgroup>
                            <optgroup label="🔧 Laboratory and Maintenance Tools">
                                <option value="Computer Toolkit">Computer Toolkit</option>
                                <option value="Crimping Tool">Crimping Tool</option>
                                <option value="Cable Tester">Cable Tester</option>
                                <option value="LAN Tester">LAN Tester</option>
                                <option value="Anti-static Wrist Strap">Anti-static Wrist Strap</option>
                            </optgroup>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Resource Name *</label>
                        <input type="text" name="resource_name" class="form-control"
                               id="resourceNameInput"
                               placeholder="e.g. Lecture Hall A, Lab 1, Projector 01" required>
                        <small style="color:#666; font-size:0.8rem;">
                            Give it a specific name to identify it (e.g. "Projector 01", "Lab 2")
                        </small>
                    </div>
                </div>

                <div class="form-row">
                    <!-- Capacity - shown for spaces only -->
                    <div class="form-group" id="capacityField">
                        <label>Capacity <span id="capacityLabel">(number of seats)</span></label>
                        <input type="number" name="capacity" class="form-control"
                               placeholder="e.g. 100" min="1">
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <input type="text" name="description" class="form-control"
                               placeholder="Brief description of the resource">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    ➕ Add Resource
                </button>
            </form>
        </div>

        <!-- Resources Table grouped by type -->
        <div class="card">
            <div class="card-header">
                <h2>🏛️ All Resources</h2>
            </div>
            <% if (resources.length > 0) { %>

            <!-- Filter bar -->
            <div style="padding: 15px 20px; border-bottom: 1px solid #eee;">
                <label style="font-weight:600; margin-right:10px;">Filter by type:</label>
                <select id="filterSelect" onchange="filterResources()" class="form-control" style="width:auto; display:inline-block;">
                    <option value="all">All Resources</option>
                    <option value="Lecture Hall">Lecture Halls</option>
                    <option value="Computer Lab">Computer Labs</option>
                    <option value="Conference Room">Conference Rooms</option>
                    <option value="equipment">Equipment</option>
                </select>
            </div>

            <div class="table-container">
                <table id="resourcesTable">
                    <thead>
                        <tr>
                            <th>Resource Name</th>
                            <th>Type</th>
                            <th>Capacity</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% resources.forEach(resource => { %>
                        <tr data-type="<%= resource.resource_type %>">
                            <td><strong><%= resource.resource_name %></strong></td>
                            <td><span class="badge badge-info"><%= resource.resource_type %></span></td>
                            <td><%= resource.capacity || '—' %></td>
                            <td><%= resource.description || '—' %></td>
                            <td>
                                <span class="badge badge-<%= resource.status %>">
                                    <%= resource.status === 'available' ? '✅ Available' :
                                        resource.status === 'unavailable' ? '❌ Unavailable' : '🔧 Maintenance' %>
                                </span>
                            </td>
                            <td>
                                <form action="/admin/resources/update/<%= resource.id %>" method="POST" style="display:inline;">
                                    <select name="status" class="form-control"
                                            style="width:auto; display:inline; padding:4px 8px; font-size:0.8rem;">
                                        <option value="available" <%= resource.status === 'available' ? 'selected' : '' %>>Available</option>
                                        <option value="unavailable" <%= resource.status === 'unavailable' ? 'selected' : '' %>>Unavailable</option>
                                        <option value="maintenance" <%= resource.status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                                    </select>
                                    <input type="hidden" name="resource_name" value="<%= resource.resource_name %>">
                                    <input type="hidden" name="resource_type" value="<%= resource.resource_type %>">
                                    <input type="hidden" name="description" value="<%= resource.description %>">
                                    <input type="hidden" name="capacity" value="<%= resource.capacity %>">
                                    <button type="submit" class="btn btn-warning btn-sm">💾 Update</button>
                                </form>
                                <a href="/admin/resources/delete/<%= resource.id %>"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Delete this resource?')">🗑️ Delete</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">🏛️</div>
                <p>No resources added yet. Add your first resource above.</p>
            </div>
            <% } %>
        </div>

    </main>
</div>

<footer class="footer">
    <p>© <%= new Date().getFullYear() %> Department of Information Technology, SICT, FUT Minna</p>
</footer>

<script>
    const spaceTypes = ['Lecture Hall', 'Computer Lab', 'Conference Room'];

    function handleResourceTypeChange() {
        const type = document.getElementById('resourceTypeSelect').value;
        const nameInput = document.getElementById('resourceNameInput');
        const capacityField = document.getElementById('capacityField');
        const capacityLabel = document.getElementById('capacityLabel');

        // Auto fill name placeholder based on type
        if (type === 'Lecture Hall') {
            nameInput.placeholder = 'e.g. Lecture Hall A, Hall 101';
            capacityField.style.display = 'block';
            capacityLabel.textContent = '(number of seats)';
        } else if (type === 'Computer Lab') {
            nameInput.placeholder = 'e.g. Lab 1, ICT Lab 2';
            capacityField.style.display = 'block';
            capacityLabel.textContent = '(number of computers)';
        } else if (type === 'Conference Room') {
            nameInput.placeholder = 'e.g. Conference Room A';
            capacityField.style.display = 'block';
            capacityLabel.textContent = '(number of seats)';
        } else {
            // Equipment
            nameInput.placeholder = `e.g. ${type} 01`;
            capacityField.style.display = 'none';
        }
    }

    function filterResources() {
        const filter = document.getElementById('filterSelect').value;
        const rows = document.querySelectorAll('#resourcesTable tbody tr');
        const spaceTypes = ['Lecture Hall', 'Computer Lab', 'Conference Room'];

        rows.forEach(row => {
            const type = row.getAttribute('data-type');
            if (filter === 'all') {
                row.style.display = '';
            } else if (filter === 'equipment') {
                row.style.display = !spaceTypes.includes(type) ? '' : 'none';
            } else {
                row.style.display = type === filter ? '' : 'none';
            }
        });
    }
</script>

</body>
</html>
