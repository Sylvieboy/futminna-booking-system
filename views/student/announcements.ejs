<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Announcements - FUT Minna</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h6>Logged in as</h6>
            <p>👤 <%= user.full_name %></p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/student/dashboard"><span class="icon">🏠</span> Dashboard</a></li>
            <li><a href="/student/resources"><span class="icon">🏛️</span> Browse Resources</a></li>
            <li><a href="/student/bookings"><span class="icon">📋</span> My Bookings</a></li>
            <li><a href="/student/appointments"><span class="icon">📅</span> Appointments</a></li>
            <li><a href="/student/announcements" class="active"><span class="icon">📢</span> Announcements</a></li>
            <li><a href="/logout"><span class="icon">🚪</span> Logout</a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="page-header">
            <h1>📢 Departmental Announcements</h1>
            <p>Stay updated with the latest news from the department</p>
        </div>

        <% if (announcements.length > 0) { %>
            <% announcements.forEach(a => { %>
            <div class="announcement-item" style="max-width:100%;">
                <h4>📢 <%= a.title %></h4>
                <p><%= a.content %></p>
                <p class="date">📅 <%= new Date(a.posted_at).toDateString() %></p>
            </div>
            <% }) %>
        <% } else { %>
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <p>No announcements have been posted yet. Check back later.</p>
        </div>
        <% } %>
    </main>
</div>

<footer class="footer">
    <p>© <%= new Date().getFullYear() %> Department of Information Technology, SICT, FUT Minna</p>
</footer>

</body>
</html>