<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Resources - FUT Minna</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('../partials/navbar') %>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <h6>Logged in as</h6>
            <p>👤 <%= user.full_name %></p>
        </div>
        <ul class="sidebar-nav">
            <li><a href="/student/dashboard"><span class="icon">🏠</span> Dashboard</a></li>
            <li><a href="/student/resources" class="active"><span class="icon">🏛️</span> Browse Resources</a></li>
            <li><a href="/student/bookings"><span class="icon">📋</span> My Bookings</a></li>
            <li><a href="/student/appointments"><span class="icon">📅</span> Appointments</a></li>
            <li><a href="/student/announcements"><span class="icon">📢</span> Announcements</a></li>
            <li><a href="/logout"><span class="icon">🚪</span> Logout</a></li>
        </ul>
    </aside>

    <main class="main-content">
        <div class="page-header">
            <h1>🏛️ Available Resources</h1>
            <p>Browse all available departmental resources</p>
        </div>

        <%- include('../partials/messages') %>

        <% if (resources.length > 0) { %>
        <div class="resources-grid">
            <% resources.forEach(resource => { %>
            <div class="resource-card">
                <h3>
                    <% if(resource.resource_type === 'hall') { %>🏛️
                    <% } else if(resource.resource_type === 'lab') { %>💻
                    <% } else { %>🔧<% } %>
                    <%= resource.resource_name %>
                </h3>
                <p><%= resource.description || 'No description provided.' %></p>
                <div class="resource-meta">
                    <span class="badge badge-<%= resource.resource_type %>"><%= resource.resource_type %></span>
                    <span class="badge badge-available">Available</span>
                </div>
                <% if (resource.capacity) { %>
                <p style="font-size:0.82rem; color:#888; margin-bottom:14px;">
                    👥 Capacity: <%= resource.capacity %> persons
                </p>
                <% } %>
                <a href="/student/bookings" class="btn btn-primary btn-sm" style="width:100%; justify-content:center;">
                    Book Now →
                </a>
            </div>
            <% }) %>
        </div>
        <% } else { %>
        <div class="empty-state">
            <div class="empty-icon">🏛️</div>
            <p>No resources available at the moment. Check back later.</p>
        </div>
        <% } %>
    </main>
</div>

<footer class="footer">
    <p>© <%= new Date().getFullYear() %> Department of Information Technology, SICT, FUT Minna</p>
</footer>

</body>
</html>